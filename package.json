{
  "name": "leiautes-devs",
  "version": "0.1.1",
  "description": "A Quasar Project",
  "productName": "Leiautes Para Devs",
  "author": "ratto <rattopedro@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "prettier --write \"**/*.{js,ts,vue,css,scss,html,md,json}\" --ignore-path .gitignore --ignore-path .prettierignore && eslint --fix -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "lint:check": "prettier \"**/*.{js,ts,vue,css,scss,html,md,json}\" --ignore-path .gitignore --ignore-path .prettierignore && eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "dev": "quasar dev",
    "build": "quasar build",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "postinstall": "quasar prepare --silent"
  },
  "dependencies": {
    "@quasar/extras": "^2.0.0",
    "pinia": "^3.0.1",
    "quasar": "^2.20.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@quasar/app-vite": "^2.6.2",
    "@types/node": "^22.19.11",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.0",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.3"
  },
  "keywords": [
    "quasar",
    "quasar-app",
    "quasar-cli",
    "quasar-app-vite",
    "vite",
    "vue",
    "vuejs"
  ],
  "engines": {
    "node": ">= 26 || ^24 || ^22.12"
  }
}
